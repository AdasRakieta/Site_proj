%%{init: { 'theme': 'default' } }%%
sequenceDiagram
    autonumber
    participant Client as Klient A
    participant Socket as Serwer_SocketIO
    participant Routes as RoutesManager
    participant DBManager as MultiHomeDBManager
    participant PG as Baza_Danych
    participant Clients as Klienci_A_B_C

    Note over Client,Socket: Użytkownik kliknie przełącznik

    Client->>Socket: emit 'toggle_button'(room, name, state)
    Socket->>Routes: otrzymaj dane + session (user_id, current_home_id)

    alt brak `current_home_id`
        Routes-->>Socket: emit 'error' {"message":"No home selected"}
        Socket-->>Client: 'error'
    else
        Routes->>DBManager: get_buttons(current_home_id, user_id)
        DBManager-->>Routes: lista przycisków
        Routes->>Routes: porównaj name/room (normalizacja)
        alt przycisk nie znaleziony
            Routes-->>Socket: emit 'error' {"message":"Button not found"}
            Socket-->>Client: 'error'
        else przycisk znaleziony
            Routes->>DBManager: update_device(device_id, user_id, state=...)
            DBManager->>PG: UPDATE devices SET state=... WHERE id=...
            PG-->>DBManager: OK / commit
            DBManager-->>Routes: True
            alt update nieudane
                Routes-->>Socket: emit 'error' {"message":"Failed to toggle button"}
                Socket-->>Client: 'error'
            else update OK
                Routes->>Socket: socketio.emit('update_button', {room, name, state, device_id})
                Socket-->>Clients: 'update_button' (broadcast do połączonych klientów)
            end
        end
    end

    Note over Socket: Uwaga: obecna implementacja broadcastuje globalnie (brak join_room)

